<html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Countdown</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Space+Mono:wght@400&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    width: 100%;
    height: 100%;
    background: #1e1e1e;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .widget {
    width: 100%;
    max-width: 260px;
    padding: 14px 16px;
  }

  .label {
    font-family: 'Space Mono', monospace;
    font-size: 7px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #444;
    margin-bottom: 12px;
  }

  .label span { color: #777; }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
    text-align: center;
  }

  .unit { display: flex; flex-direction: column; align-items: center; gap: 4px; }

  .num {
    font-family: 'Share Tech Mono', monospace;
    font-size: 22px;
    color: #ddd;
    line-height: 1;
    transition: color 0.1s;
  }

  .num.tick { color: #fff; }

  .u {
    font-family: 'Space Mono', monospace;
    font-size: 6px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #383838;
  }

  .bar-row {
    margin-top: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .event {
    font-family: 'Space Mono', monospace;
    font-size: 6.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #333;
  }

  .bar {
    width: 50px;
    height: 1.5px;
    background: #282828;
    border-radius: 2px;
    overflow: hidden;
  }

  .fill {
    height: 100%;
    background: #4a4a4a;
    border-radius: 2px;
    transition: width 1s linear;
  }
</style>
</head>
<body>
<div class="widget">
  <div class="label">to — <span>mid-year exams</span></div>
  <div class="grid">
    <div class="unit"><div class="num" id="M">00</div><div class="u">mo</div></div>
    <div class="unit"><div class="num" id="D">00</div><div class="u">dy</div></div>
    <div class="unit"><div class="num" id="H">00</div><div class="u">hr</div></div>
    <div class="unit"><div class="num" id="S">00</div><div class="u">sc</div></div>
  </div>
  <div class="bar-row">
    <div class="event">7 jul 2026</div>
    <div class="bar"><div class="fill" id="fill"></div></div>
  </div>
</div>
<script>
  const target = new Date('2026-07-07T09:00:00');
  const start  = new Date('2026-03-04T00:00:00');
  const pad = n => String(Math.floor(n)).padStart(2,'0');
  let lastS = -1;

  function tick(el){ el.classList.add('tick'); setTimeout(()=>el.classList.remove('tick'),120); }

  function update(){
    const now  = new Date();
    const diff = target - now;
    if(diff <= 0){ ['M','D','H','S'].forEach(id=>document.getElementById(id).textContent='00'); return; }

    const totalDays = Math.floor(diff / 864e5);
    const mo = Math.floor(totalDays / 30.44);
    const dy = Math.floor(totalDays % 30.44);
    const hr = Math.floor((diff % 864e5) / 36e5);
    const sc = Math.floor((diff % 6e4)  / 1e3);

    document.getElementById('M').textContent = pad(mo);
    document.getElementById('D').textContent = pad(dy);
    document.getElementById('H').textContent = pad(hr);

    const sEl = document.getElementById('S');
    if(sc !== lastS){ sEl.textContent = pad(sc); tick(sEl); lastS = sc; }

    const pct = Math.min(100, Math.max(0, (now - start)/(target - start)*100));
    document.getElementById('fill').style.width = pct + '%';
  }

  update();
  setInterval(update, 250);
</script>
</body>
</html>
